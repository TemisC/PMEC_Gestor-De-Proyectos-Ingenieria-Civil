# Copiar a .env y completar con valores reales (nunca commitear .env).
# Ver "Cómo continuar en otra máquina/red" en plan_maestro.md.

# Postgres real (Supabase) — pooler en modo transaction (6543), para el runtime de la app.
# Sacar del dashboard de Supabase: Project Settings > Database > Connection string > Transaction pooler.
DATABASE_URL=

# Pooler en modo session (5432), sin pgbouncer — solo para `prisma migrate` (ver prisma.config.ts).
# Mismo lugar que arriba, pero "Session pooler".
DIRECT_URL=

# Auth.js (NextAuth) — secreto para firmar sesiones/JWT. Generar con:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Solo en CI/entornos sin TLS (ver docs/gotchas.md) — omitir en desarrollo normal contra Supabase.
# DATABASE_SSL=false
