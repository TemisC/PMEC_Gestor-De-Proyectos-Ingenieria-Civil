// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Ampliación post-MVP anticipada (2026-07-21): el MVP mínimo (solo
// User/Project/TimeEntry) no alcanzaba para demostrarle a Deltana lo que
// más le importa a Gerencia — previsión de cobro y rentabilidad. Se
// adelanta acá la lógica financiera básica (Etapas 5/6 del plan),
// portando fielmente el modelo del SPA original (types.ts: Agreement,
// Additional, PlannedInvoice, Invoice) — ver plan_maestro.md para la
// nota completa sobre este cambio de secuencia y el riesgo aceptado
// (Etapa 0 — validación con el dueño de la lógica — sigue pendiente).
enum Role {
  GERENCIA
  GESTOR
  COLABORADOR
}

enum InvoiceSource {
  AGREEMENT
  ADDITIONAL
}

enum ClientContactType {
  TECHNICAL
  ECONOMIC
}

// Archivar (no borrar) es la única forma de "cerrar" un proyecto — decisión
// explícita del usuario (2026-07-22): preserva toda la info financiera/horas
// para siempre, solo cambia de qué lista aparece por default. Archivar NO
// bloquea seguir editando/cargando horas (simplificación deliberada de esta
// tanda; ver plan_maestro.md si en el futuro se pide bloquear ediciones).
enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

// Cliente — entidad GLOBAL de toda Deltana, no de un Gestor en
// particular (mismo criterio que colaboradores/tarifas — sección 2 del
// plan: "catálogos compartidos... evita que dos consultores dupliquen
// el mismo cliente"). Cualquier Gestor/Gerencia puede verlo y crear
// proyectos contra él; el detalle financiero de cada proyecto sigue
// restringido como siempre.
model Client {
  id   String @id @default(cuid())
  name String @unique

  generalContactName  String?
  generalContactEmail String?
  generalContactPhone String?

  contacts ClientContact[]
  projects Project[]

  createdAt DateTime @default(now())
}

// Contactos técnicos/económicos del cliente — mismo concepto que
// technicalContacts/economicContacts del SPA original (para saber a
// quién escribirle según si es una consulta técnica o de facturación).
model ClientContact {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  type  ClientContactType
  name  String
  email String?
  phone String?

  createdAt DateTime @default(now())
}

model User {
  id                String  @id @default(cuid())
  email             String  @unique
  name              String?
  password          String
  role              Role    @default(COLABORADOR)
  // false = desactivado (no puede loguear, igual que "Archivado" en proyectos).
  // El historial de horas y proyectos se conserva intacto.
  active            Boolean @default(true)
  // Tarifa hora por defecto (coste interno) — el ProjectMember.hourlyRate
  // la puede sobreescribir por proyecto, igual que el SPA original
  // (internalRates global + override por proyecto en internalCostInfo).
  defaultHourlyRate Float?

  managedProjects Project[]       @relation("ProjectManager")
  assignments     ProjectMember[]
  timeEntries     TimeEntry[]

  createdAt DateTime @default(now())
}

model Project {
  id     String        @id @default(cuid())
  name   String
  status ProjectStatus @default(ACTIVE)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  managerId String
  manager   User   @relation("ProjectManager", fields: [managerId], references: [id])

  members              ProjectMember[]
  timeEntries          TimeEntry[]
  agreement            ProjectAgreement?
  additionals          ProjectAdditional[]
  plannedInvoices      PlannedInvoice[]
  invoices             Invoice[]
  externalCollaborators ExternalCollaborator[]

  createdAt DateTime @default(now())
}

model ProjectMember {
  id String @id @default(cuid())

  userId    String
  projectId String
  user      User    @relation(fields: [userId], references: [id])
  project   Project @relation(fields: [projectId], references: [id])

  // Override de tarifa hora para este colaborador en este proyecto
  // específico; si es null, se usa User.defaultHourlyRate.
  hourlyRate Float?

  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model TimeEntry {
  id          String   @id @default(cuid())
  date        DateTime
  hours       Float
  description String?

  userId    String
  projectId String
  user      User    @relation(fields: [userId], references: [id])
  project   Project @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
}

// El acuerdo/contrato principal del proyecto (el "presupuesto base").
// Uno solo por proyecto — de ahí sale la base de la previsión de cobro.
model ProjectAgreement {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id])

  amount      Float
  offerUrl    String?
  contractUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Adicionales al acuerdo original (trabajo extra fuera del alcance base).
model ProjectAdditional {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  description String
  amount      Float
  url         String?

  createdAt DateTime @default(now())
}

// Previsión de facturación (cuándo se espera cobrar, no lo ya cobrado)
// — la pieza central para que Gerencia vea rentabilidad ANTES de que el
// proyecto cierre, que era el pedido de negocio original.
model PlannedInvoice {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  description String
  date        DateTime
  amount      Float
  source      InvoiceSource @default(AGREEMENT)
  // Se marca true cuando se "promueve" a factura real emitida (Invoice).
  invoiced    Boolean       @default(false)

  createdAt DateTime @default(now())
}

// Facturas ya emitidas (cobro real, no previsto).
model Invoice {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  amount Float
  date   DateTime
  pdfUrl String?
  source InvoiceSource @default(AGREEMENT)

  createdAt DateTime @default(now())
}

// Colaborador externo (subcontratista) — a diferencia de un Colaborador
// interno (User con rol COLABORADOR, que carga horas), un externo no es
// un usuario del sistema: se le paga por acuerdo/adicionales, no por
// hora. Mismo concepto que CollaboratorInfo del SPA original.
model ExternalCollaborator {
  id      String  @id @default(cuid())
  name    String
  company String?
  contact String?

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  agreementAmount Float?
  agreementUrl    String?

  additionals ExternalCollaboratorAdditional[]
  payments    ExternalCollaboratorPayment[]

  createdAt DateTime @default(now())
}

model ExternalCollaboratorAdditional {
  id                     String               @id @default(cuid())
  externalCollaboratorId String
  externalCollaborator   ExternalCollaborator @relation(fields: [externalCollaboratorId], references: [id])

  description String
  amount      Float

  createdAt DateTime @default(now())
}

// Pago real ya realizado al colaborador externo (equivalente a
// ReceivedInvoice del SPA original) — es lo que cuenta como coste
// externo real en la rentabilidad, igual que el coste interno se basa
// en horas ya cargadas, no en previsiones.
model ExternalCollaboratorPayment {
  id                     String               @id @default(cuid())
  externalCollaboratorId String
  externalCollaborator   ExternalCollaborator @relation(fields: [externalCollaboratorId], references: [id])

  amount      Float
  date        DateTime
  description String?

  createdAt DateTime @default(now())
}
